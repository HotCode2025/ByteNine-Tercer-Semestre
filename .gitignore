# ============================================================================
# .GITIGNORE UNIVERSAL - TECNICATURA (Python, Java, JS)
# ============================================================================

# --- SISTEMA OPERATIVO ---
# Bloquea archivos basura de Windows que no aportan al código
desktop.ini
# Archivo oculto de miniaturas de imágenes.
Thumbs.db
# Equivalente a desktop.ini para usuarios de Mac.
.DS_Store

# --- LINUX ---
# Archivo de configuración de visualización de carpetas (opcional)
.directory

# ============================================================================
# --- PYTHON (PyCharm / Ambientes Virtuales) ---
# .idea/: Configuración personal del IDE.
.idea/
# _pycache_/: Archivos temporales de ejecución.
_pycache_/
# *.pyc: Archivos de Python compilados.
*.pyc
# venv/ y .venv/: Entornos virtuales (Estándar y Oculto).
venv/
.venv/

# ============================================================================
# --- JAVA (Apache NetBeans e IntelliJ IDEA) ---
# NetBeans specific
/.cache/
/.nb-gradle-properties
/.nb-gradle-version

# Carpetas y archivos de Configuración Local de NetBeans que causaban el problema
nbproject/private/

# Metadatos de Eclipse (si alguien del equipo usa este IDE)
.classpath
.project
.settings/

# ============================================================================
# --- JAVASCRIPT (VS Code / Node.js / Quokka) ---
# node_modules/: Librerías externas pesadas.
#Porque es como llevar los ladrillos cuando mandás los planos de una casa. 
#Es mejor mandar solo los planos (el código) y que cada uno compre sus ladrillos
# en su ciudad (instalación local).
node_modules/
# .quokka/: Archivos temporales de la extensión Quokka.
.quokka/
# .cache/ y .npm/: Datos temporales de motores JS y Node.js.
.cache/
.npm/
# coverage/: Reportes de pruebas (Testing).
coverage/
# .vscode/: Configuraciones del editor y .env: Seguridad (Contraseñas).
.vscode/
.env

# ============================================================================
# --- EXTRAS Y MANTENIMIENTO ---
# *.log: Registros de errores locales.
*.log
# tmp/: Carpeta de archivos temporales.
tmp/
# --- ARCHIVOS COMPRIMIDOS ---
# Bloquea respaldos pesados que ocupan espacio innecesario.
#Porque en GitHub se sube el código "suelto". Si alguien sube un .zip,
# Git no puede ver qué cambió adentro y el historial de versiones se pierde.
*.zip
*.rar
*.7z

# ============================================================================
# --- BASES DE DATOS (SQL / Workbench) ---
# Bloquea archivos de recuperación y configuraciones de conexión
*.bak
*.sql.bak
.temp/
/Tecnicatura3J/Leccion01/MundoPC/nbproject/private/
/Tecnicatura3J/Leccion01/MundoPC/build/
/Tecnicatura3J/Leccion02/ArgumentosVariables/nbproject/private/
/Tecnicatura3J/Leccion02/ArgumentosVariables/build/
